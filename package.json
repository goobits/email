{
	"name": "@goobits/email",
	"version": "1.0.0",
	"description": "Provider-agnostic email sender with AWS SES v2, Resend, SMTP, and in-memory mock providers.",
	"type": "module",
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"sideEffects": false,
	"files": [
		"src",
		"README.md",
		"LICENSE",
		"CHANGELOG.md"
	],
	"exports": {
		".": "./src/index.ts",
		"./ses": "./src/providers/ses.ts",
		"./resend": "./src/providers/resend.ts",
		"./smtp": "./src/providers/smtp.ts"
	},
	"keywords": [
		"email",
		"smtp",
		"aws-ses",
		"transactional-email",
		"esm",
		"typescript",
		"sveltekit"
	],
	"author": "Goobits",
	"license": "MIT",
	"homepage": "https://github.com/goobits/email#readme",
	"bugs": "https://github.com/goobits/email/issues",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/goobits/email.git"
	},
	"engines": {
		"node": ">=22"
	},
	"packageManager": "pnpm@11.10.0",
	"peerDependencies": {
		"@aws-sdk/client-sesv2": "^3.0.0",
		"nodemailer": "^9.0.0",
		"resend": "^6.0.0",
		"typescript": "^5.0.0 || ^6.0.0"
	},
	"peerDependenciesMeta": {
		"@aws-sdk/client-sesv2": {
			"optional": true
		},
		"nodemailer": {
			"optional": true
		},
		"resend": {
			"optional": true
		},
		"typescript": {
			"optional": true
		}
	},
	"devDependencies": {
		"@aws-sdk/client-sesv2": "^3.1074.0",
		"@types/node": "^26.0.0",
		"@types/nodemailer": "^8.0.1",
		"@vitest/coverage-v8": "^4.1.10",
		"nodemailer": "^9.0.1",
		"resend": "^6.14.0",
		"typescript": "^6.0.3",
		"vitest": "^4.1.10"
	},
	"scripts": {
		"typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"clean": "rm -rf node_modules .turbo"
	}
}
